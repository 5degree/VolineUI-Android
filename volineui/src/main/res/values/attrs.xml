<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="InputField">
        <!-- Text Configuration -->
        <attr name="android:text" />
        <attr name="android:hint" />
        <attr name="label" format="string" />
        <attr name="android:inputType" />
        <attr name="android:maxLength" />
        
        <!-- Visual Customization -->
        <attr name="cornerRadius" format="dimension" />
        <attr name="borderColor" format="color" />
        <attr name="borderWidth" format="dimension" />
        <attr name="focusedBorderColor" format="color" />
        <attr name="focusedBorderWidth" format="dimension" />
        <attr name="backgroundColor" format="color" />
        
        <!-- State Colors -->
        <attr name="errorColor" format="color" />
        <attr name="successColor" format="color" />
        <attr name="disabledColor" format="color" />
        <attr name="loadingColor" format="color" />
        
        <!-- Feature Toggles -->
        <attr name="showClearIcon" format="boolean" />
        <attr name="showCharacterCounter" format="boolean" />
        <attr name="enableValidation" format="boolean" />
        <attr name="multiLine" format="boolean" />
        <attr name="android:enabled" />
        <attr name="readOnly" format="boolean" />
        
        <!-- Icons -->
        <attr name="prefixIcon" format="reference" />
        <attr name="suffixIcon" format="reference" />
        <attr name="clearIcon" format="reference" />
        <attr name="passwordToggleIcon" format="reference" />
        <attr name="passwordToggleVisibleIcon" format="reference" />
        
        <!-- Validation -->
        <attr name="validationType" format="enum">
            <enum name="none" value="0" />
            <enum name="email" value="1" />
            <enum name="phone" value="2" />
            <enum name="url" value="3" />
            <enum name="custom" value="4" />
        </attr>
        <attr name="customValidationPattern" format="string" />
        
        <!-- Input Masking -->
        <attr name="inputMask" format="string" />
        <attr name="maskCharacter" format="string" />
        
        <!-- Spacing -->
        <attr name="labelGap" format="dimension" />
        <attr name="iconPadding" format="dimension" />
        <attr name="verticalPadding" format="dimension" />
        <attr name="horizontalPadding" format="dimension" />
        <attr name="android:padding" />
        <attr name="android:paddingStart" />
        <attr name="android:paddingEnd" />
        <attr name="android:paddingTop" />
        <attr name="android:paddingBottom" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:textColor" />
        <attr name="labelTextSize" format="dimension" />
        <attr name="labelTextColor" format="color" />
        <attr name="hintTextColor" format="color" />
        <attr name="errorTextSize" format="dimension" />
        <attr name="counterTextSize" format="dimension" />
    </declare-styleable>
    
    <declare-styleable name="Radio">
        <!-- Options Configuration -->
        <attr name="options" format="reference" />
        <attr name="selectedIndex" format="integer" />
        
        <!-- Label -->
        <attr name="radioLabel" format="string" />
        <attr name="radioLabelGap" format="dimension" />
        <attr name="radioLabelTextSize" format="dimension" />
        <attr name="radioLabelTextColor" format="color" />
        
        <!-- Colors -->
        <attr name="selectedBackgroundColor" format="color" />
        <attr name="unselectedBackgroundColor" format="color" />
        <attr name="selectedTextColor" format="color" />
        <attr name="unselectedTextColor" format="color" />
        <attr name="containerBackgroundColor" format="color" />
        <attr name="dividerColor" />
        
        <!-- Sizing & Spacing -->
        <attr name="height" format="dimension" />
        <attr name="gap" format="dimension" />
        <attr name="optionSpacing" format="dimension"/>
        <attr name="cornerRadius" />
        
        <!-- Visual Effects -->
        <attr name="showDividers" />
        <attr name="pillElevation" format="dimension" />
        <attr name="dividerWidth" format="dimension" />
        
        <!-- Behavior -->
        <attr name="enableHapticFeedback" format="boolean" />
        <attr name="animationDuration" format="integer" />
        <attr name="enableSwipeGesture" format="boolean" />
        <attr name="android:enabled" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:fontFamily" />
        
        <!-- Text Style -->
        <attr name="selectedTextStyle" format="enum">
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="boldItalic" value="3" />
        </attr>
        <attr name="unselectedTextStyle" format="enum">
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="boldItalic" value="3" />
        </attr>
    </declare-styleable>
</resources>