<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="InputField">
        <!-- Text Configuration -->
        <attr name="android:text" />
        <attr name="android:hint" />
        <attr name="label" format="string" />
        <attr name="android:inputType" />
        <attr name="android:maxLength" />
        
        <!-- Visual Customization -->
        <attr name="cornerRadius" format="dimension" />
        <attr name="borderColor" format="color" />
        <attr name="borderWidth" format="dimension" />
        <attr name="focusedBorderColor" format="color" />
        <attr name="focusedBorderWidth" format="dimension" />
        <attr name="backgroundColor" format="color" />
        
        <!-- State Colors -->
        <attr name="errorColor" format="color" />
        <attr name="successColor" format="color" />
        <attr name="disabledColor" format="color" />
        <attr name="loadingColor" format="color" />
        
        <!-- Feature Toggles -->
        <attr name="showClearIcon" format="boolean" />
        <attr name="showCharacterCounter" format="boolean" />
        <attr name="enableValidation" format="boolean" />
        <attr name="multiLine" format="boolean" />
        <attr name="android:enabled" />
        <attr name="readOnly" format="boolean" />
        
        <!-- Icons -->
        <attr name="prefixIcon" format="reference" />
        <attr name="suffixIcon" format="reference" />
        <attr name="clearIcon" format="reference" />
        <attr name="passwordToggleIcon" format="reference" />
        <attr name="passwordToggleVisibleIcon" format="reference" />
        
        <!-- Validation -->
        <attr name="validationType" format="enum">
            <enum name="none" value="0" />
            <enum name="email" value="1" />
            <enum name="phone" value="2" />
            <enum name="url" value="3" />
            <enum name="custom" value="4" />
        </attr>
        <attr name="customValidationPattern" format="string" />
        
        <!-- Input Masking -->
        <attr name="inputMask" format="string" />
        <attr name="maskCharacter" format="string" />
        
        <!-- Spacing -->
        <attr name="labelGap" format="dimension" />
        <attr name="iconPadding" format="dimension" />
        <attr name="verticalPadding" format="dimension" />
        <attr name="horizontalPadding" format="dimension" />
        <attr name="android:padding" />
        <attr name="android:paddingStart" />
        <attr name="android:paddingEnd" />
        <attr name="android:paddingTop" />
        <attr name="android:paddingBottom" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:textColor" />
        <attr name="labelTextSize" format="dimension" />
        <attr name="labelTextColor" format="color" />
        <attr name="hintTextColor" format="color" />
        <attr name="errorTextSize" format="dimension" />
        <attr name="counterTextSize" format="dimension" />
    </declare-styleable>
    
    <declare-styleable name="Radio">
        <!-- Options Configuration -->
        <attr name="options" format="reference" />
        <attr name="selectedIndex" format="integer" />
        
        <!-- Label -->
        <attr name="radioLabel" format="string" />
        <attr name="radioLabelGap" format="dimension" />
        <attr name="radioLabelTextSize" format="dimension" />
        <attr name="radioLabelTextColor" format="color" />
        
        <!-- Colors -->
        <attr name="selectedBackgroundColor" format="color" />
        <attr name="unselectedBackgroundColor" format="color" />
        <attr name="selectedTextColor" format="color" />
        <attr name="unselectedTextColor" format="color" />
        <attr name="containerBackgroundColor" format="color" />
        <attr name="dividerColor" />
        
        <!-- Sizing & Spacing -->
        <attr name="height" format="dimension" />
        <attr name="gap" format="dimension" />
        <attr name="optionSpacing" format="dimension"/>
        <attr name="cornerRadius" />
        
        <!-- Visual Effects -->
        <attr name="showDividers" />
        <attr name="pillElevation" format="dimension" />
        <attr name="dividerWidth" format="dimension" />
        
        <!-- Behavior -->
        <attr name="enableHapticFeedback" format="boolean" />
        <attr name="animationDuration" format="integer" />
        <attr name="enableSwipeGesture" format="boolean" />
        <attr name="android:enabled" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:fontFamily" />
        
        <!-- Text Style -->
        <attr name="selectedTextStyle" format="enum">
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="boldItalic" value="3" />
        </attr>
        <attr name="unselectedTextStyle" format="enum">
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="boldItalic" value="3" />
        </attr>
    </declare-styleable>
    
    <declare-styleable name="Dropdown">
        <!-- Options Data -->
        <attr name="options" />
        
        <!-- Text Configuration -->
        <attr name="label" />
        <attr name="android:hint" />
        <attr name="labelGap" />
        
        <!-- Visual Customization -->
        <attr name="containerStyle" format="enum">
            <enum name="outlined" value="0" />
            <enum name="filled" value="1" />
            <enum name="ghost" value="2" />
        </attr>
        <attr name="cornerRadius" />
        <attr name="borderColor" />
        <attr name="borderWidth" />
        <attr name="focusedBorderColor" />
        <attr name="focusedBorderWidth" />
        <attr name="backgroundColor" />
        <attr name="expandedBorderColor" format="color" />
        <attr name="dropdownElevation" format="dimension" />
        <attr name="verticalPadding" />
        <attr name="horizontalPadding" />
        
        <!-- Selection Mode -->
        <attr name="selectionMode" format="enum">
            <enum name="single" value="0" />
            <enum name="multi" value="1" />
        </attr>
        <attr name="maxSelections" format="integer" />
        <attr name="showSelectAll" format="boolean" />
        <attr name="collapseChipsAfter" format="integer" />
        
        <!-- Icons -->
        <attr name="leadingIcon" format="reference" />
        <attr name="leadingIconTint" format="color" />
        <attr name="trailingIcon" format="reference" />
        <attr name="trailingIconTint" format="color" />
        <attr name="animateTrailingIcon" format="boolean" />
        <attr name="showClearButton" format="boolean" />
        <attr name="clearIcon" />
        <attr name="clearIconTint" format="color" />
        <attr name="emptyStateIcon" format="reference" />
        <attr name="loadingIcon" format="reference" />
        
        <!-- Search & Filter -->
        <attr name="searchable" format="boolean" />
        <attr name="searchHint" format="string" />
        <attr name="searchDebounceMs" format="integer" />
        <attr name="highlightMatches" format="boolean" />
        <attr name="showCreateOption" format="boolean" />
        
        <!-- Dropdown Behavior -->
        <attr name="openAnimation" format="enum">
            <enum name="none" value="0" />
            <enum name="fade" value="1" />
            <enum name="scale" value="2" />
            <enum name="slide" value="3" />
        </attr>
        <attr name="closeAnimation" format="enum">
            <enum name="none" value="0" />
            <enum name="fade" value="1" />
            <enum name="scale" value="2" />
            <enum name="slide" value="3" />
        </attr>
        <attr name="animationDuration" />
        <attr name="showBackdrop" format="boolean" />
        <attr name="backdropColor" format="color" />
        <attr name="dismissOnClickOutside" format="boolean" />
        <attr name="autoFlipPosition" format="boolean" />
        <attr name="scrollToSelected" format="boolean" />
        
        <!-- Option Styling -->
        <attr name="optionHeight" format="dimension" />
        <attr name="optionPadding" format="dimension" />
        <attr name="optionHoverColor" format="color" />
        <attr name="optionSelectedColor" format="color" />
        <attr name="optionTextColor" format="color" />
        <attr name="optionSelectedTextColor" format="color" />
        <attr name="showCheckmarks" format="boolean" />
        <attr name="showDividers" />
        
        <!-- State Colors -->
        <attr name="errorColor" />
        <attr name="successColor" />
        <attr name="disabledColor" />
        <attr name="loadingColor" />
        <attr name="required" format="boolean" />
        
        <!-- Chip Styling -->
        <attr name="chipBackgroundColor" format="color" />
        <attr name="chipTextColor" format="color" />
        <attr name="chipCornerRadius" format="dimension" />
        <attr name="chipHeight" format="dimension" />
        <attr name="chipSpacing" format="dimension" />
        
        <!-- Accessibility -->
        <attr name="android:contentDescription" />
        <attr name="announceSelection" format="boolean" />
        
        <!-- Advanced -->
        <attr name="useVirtualScrolling" format="boolean" />
        <attr name="virtualScrollThreshold" format="integer" />
        <attr name="enableHapticFeedback" />
        
        <!-- Common Attributes -->
        <attr name="android:enabled" />
        <attr name="readOnly" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:textColor" />
        <attr name="labelTextSize" />
        <attr name="labelTextColor" />
        <attr name="hintTextColor" />
    </declare-styleable>
</resources>