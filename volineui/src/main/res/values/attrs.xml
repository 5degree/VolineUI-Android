<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="InputField">
        <!-- Text Configuration -->
        <attr name="android:text" />
        <attr name="android:hint" />
        <attr name="label" format="string" />
        <attr name="android:inputType" />
        <attr name="android:maxLength" />
        <attr name="android:ellipsize" />
        
        <!-- Visual Customization -->
        <attr name="cornerRadius" format="dimension" />
        <attr name="borderColor" format="color" />
        <attr name="borderWidth" format="dimension" />
        <attr name="focusedBorderColor" format="color" />
        <attr name="focusedBorderWidth" format="dimension" />
        <attr name="backgroundColor" format="color" />
        
        <!-- State Colors -->
        <attr name="errorColor" format="color" />
        <attr name="successColor" format="color" />
        <attr name="disabledColor" format="color" />
        <attr name="loadingColor" format="color" />
        
        <!-- Feature Toggles -->
        <attr name="showClearIcon" format="boolean" />
        <attr name="showCharacterCounter" format="boolean" />
        <attr name="enableValidation" format="boolean" />
        <attr name="multiLine" format="boolean" />
        <attr name="android:enabled" />
        <attr name="readOnly" format="boolean" />
        
        <!-- Icons -->
        <attr name="prefixIcon" format="reference" />
        <attr name="suffixIcon" format="reference" />
        <attr name="clearIcon" format="reference" />
        <attr name="passwordToggleIcon" format="reference" />
        <attr name="passwordToggleVisibleIcon" format="reference" />
        
        <!-- Validation -->
        <attr name="validationType" format="enum">
            <enum name="none" value="0" />
            <enum name="email" value="1" />
            <enum name="phone" value="2" />
            <enum name="url" value="3" />
            <enum name="custom" value="4" />
        </attr>
        <attr name="customValidationPattern" format="string" />
        
        <!-- Input Masking -->
        <attr name="inputMask" format="string" />
        <attr name="maskCharacter" format="string" />
        
        <!-- Spacing -->
        <attr name="labelGap" format="dimension" />
        <attr name="iconPadding" format="dimension" />
        <attr name="verticalPadding" format="dimension" />
        <attr name="horizontalPadding" format="dimension" />
        <attr name="android:padding" />
        <attr name="android:paddingStart" />
        <attr name="android:paddingEnd" />
        <attr name="android:paddingTop" />
        <attr name="android:paddingBottom" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:textColor" />
        <attr name="labelTextSize" format="dimension" />
        <attr name="labelTextColor" format="color" />
        <attr name="hintTextColor" format="color" />
        <attr name="errorTextSize" format="dimension" />
        <attr name="counterTextSize" format="dimension" />
    </declare-styleable>
    
    <declare-styleable name="Radio">
        <!-- Options Configuration -->
        <attr name="options" format="reference" />
        <attr name="selectedIndex" format="integer" />
        
        <!-- Label -->
        <attr name="radioLabel" format="string" />
        <attr name="radioLabelGap" format="dimension" />
        <attr name="radioLabelTextSize" format="dimension" />
        <attr name="radioLabelTextColor" format="color" />
        
        <!-- Colors -->
        <attr name="selectedBackgroundColor" format="color" />
        <attr name="unselectedBackgroundColor" format="color" />
        <attr name="selectedTextColor" format="color" />
        <attr name="unselectedTextColor" format="color" />
        <attr name="containerBackgroundColor" format="color" />
        <attr name="dividerColor" />
        
        <!-- Sizing & Spacing -->
        <attr name="height" format="dimension" />
        <attr name="gap" format="dimension" />
        <attr name="optionSpacing" format="dimension"/>
        <attr name="cornerRadius" />
        
        <!-- Visual Effects -->
        <attr name="showDividers" />
        <attr name="pillElevation" format="dimension" />
        <attr name="dividerWidth" format="dimension" />
        
        <!-- Behavior -->
        <attr name="enableHapticFeedback" format="boolean" />
        <attr name="animationDuration" format="integer" />
        <attr name="enableSwipeGesture" format="boolean" />
        <attr name="android:enabled" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:fontFamily" />
        
        <!-- Text Style -->
        <attr name="selectedTextStyle" format="enum">
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="boldItalic" value="3" />
        </attr>
        <attr name="unselectedTextStyle" format="enum">
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="boldItalic" value="3" />
        </attr>
    </declare-styleable>
    
    <declare-styleable name="Dropdown">
        <!-- Options Data -->
        <attr name="options" />
        
        <!-- Text Configuration -->
        <attr name="label" />
        <attr name="android:hint" />
        <attr name="labelGap" />
        <attr name="emptyMsg" format="string" />
        
        <!-- Visual Customization -->
        <attr name="containerStyle" format="enum">
            <enum name="outlined" value="0" />
            <enum name="filled" value="1" />
            <enum name="ghost" value="2" />
        </attr>
        <attr name="cornerRadius" />
        <attr name="borderColor" />
        <attr name="borderWidth" />
        <attr name="focusedBorderColor" />
        <attr name="focusedBorderWidth" />
        <attr name="backgroundColor" />
        <attr name="expandedBorderColor" format="color" />
        <attr name="dropdownElevation" format="dimension" />
        <attr name="verticalPadding" />
        <attr name="horizontalPadding" />
        
        <!-- Selection Mode -->
        <attr name="selectionMode" format="enum">
            <enum name="single" value="0" />
            <enum name="multi" value="1" />
        </attr>
        <attr name="maxSelections" format="integer" />
        <attr name="showSelectAll" format="boolean" />
        <attr name="collapseChipsAfter" format="integer" />
        
        <!-- Icons -->
        <attr name="leadingIcon" format="reference" />
        <attr name="leadingIconTint" format="color" />
        <attr name="trailingIcon" format="reference" />
        <attr name="trailingIconTint" format="color" />
        <attr name="animateTrailingIcon" format="boolean" />
        <attr name="showClearButton" format="boolean" />
        <attr name="clearIcon" />
        <attr name="clearIconTint" format="color" />
        <attr name="emptyStateIcon" format="reference" />
        <attr name="loadingIcon" format="reference" />
        
        <!-- Search & Filter -->
        <attr name="searchable" format="boolean" />
        <attr name="searchHint" format="string" />
        <attr name="searchDebounceMs" format="integer" />
        <attr name="highlightMatches" format="boolean" />
        <attr name="showCreateOption" format="boolean" />
        
        <!-- Dropdown Behavior -->
        <attr name="openAnimation" format="enum">
            <enum name="none" value="0" />
            <enum name="fade" value="1" />
            <enum name="scale" value="2" />
            <enum name="slide" value="3" />
        </attr>
        <attr name="closeAnimation" format="enum">
            <enum name="none" value="0" />
            <enum name="fade" value="1" />
            <enum name="scale" value="2" />
            <enum name="slide" value="3" />
        </attr>
        <attr name="animationDuration" />
        <attr name="showBackdrop" format="boolean" />
        <attr name="backdropColor" format="color" />
        <attr name="dismissOnClickOutside" format="boolean" />
        <attr name="autoFlipPosition" format="boolean" />
        <attr name="scrollToSelected" format="boolean" />
        
        <!-- Option Styling -->
        <attr name="optionHeight" format="dimension" />
        <attr name="optionPadding" format="dimension" />
        <attr name="optionHoverColor" format="color" />
        <attr name="optionSelectedColor" format="color" />
        <attr name="optionTextColor" format="color" />
        <attr name="optionSelectedTextColor" format="color" />
        <attr name="showCheckmarks" format="boolean" />
        <attr name="showDividers" />
        
        <!-- State Colors -->
        <attr name="errorColor" />
        <attr name="successColor" />
        <attr name="disabledColor" />
        <attr name="loadingColor" />
        <attr name="required" format="boolean" />
        
        <!-- Chip Styling -->
        <attr name="chipBackgroundColor" format="color" />
        <attr name="chipTextColor" format="color" />
        <attr name="chipCornerRadius" format="dimension" />
        <attr name="chipHeight" format="dimension" />
        <attr name="chipSpacing" format="dimension" />
        
        <!-- Accessibility -->
        <attr name="android:contentDescription" />
        <attr name="announceSelection" format="boolean" />
        
        <!-- Advanced -->
        <attr name="useVirtualScrolling" format="boolean" />
        <attr name="virtualScrollThreshold" format="integer" />
        <attr name="enableHapticFeedback" />
        
        <!-- Common Attributes -->
        <attr name="android:enabled" />
        <attr name="readOnly" />
        
        <!-- Text Appearance -->
        <attr name="android:textSize" />
        <attr name="android:textColor" />
        <attr name="labelTextSize" />
        <attr name="labelTextColor" />
        <attr name="hintTextColor" />
    </declare-styleable>

    <declare-styleable name="SignaturePad">
        <attr name="penColor" format="color" />
        <attr name="canvasBackgroundColor" format="color" />
        <attr name="penThickness" format="dimension" />
        <attr name="minStrokeCount" format="integer" />
        <attr name="promptText" format="string" />
        <attr name="autoTrimEmptySpace" format="boolean" />
        <attr name="signatureCornerRadius" format="dimension" />
        <attr name="signatureBorderColor" format="color" />
        <attr name="signatureBorderWidth" format="dimension" />
        <attr name="enablePressureSensitivity" format="boolean" />
        <attr name="enableSpeedBasedThickness" format="boolean" />
        <attr name="maxUndoStackSize" format="integer" />
    </declare-styleable>

    <declare-styleable name="AdvancedImageView">
        <!-- Label -->
        <attr name="imageLabel" format="string" />
        <attr name="imageLabelGap" format="dimension" />
        <attr name="imageLabelTextSize" format="dimension" />
        <attr name="imageLabelTextColor" format="color" />
        <attr name="imageLabelTextStyle" format="enum">
            <enum name="normal" value="0" />
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="bold_italic" value="3" />
        </attr>
        
        <!-- Image Source -->
        <attr name="imageSrc" format="reference" />
        
        <!-- Image Display -->
        <attr name="imageScaleType" format="enum">
            <enum name="fit" value="0" />
            <enum name="fill" value="1" />
            <enum name="crop" value="2" />
            <enum name="center" value="3" />
            <enum name="stretch" value="4" />
        </attr>
        <attr name="imageAspectRatio" format="float" />
        
        <!-- Placeholder -->
        <attr name="placeholderIcon" format="reference" />
        <attr name="placeholderText" format="string" />
        <attr name="placeholderIconColor" format="color" />
        <attr name="placeholderTextColor" format="color" />
        <attr name="placeholderGap" format="dimension" />
        
        <!-- Loading -->
        <attr name="loadingGif" format="reference" />
        
        <!-- Visual Styling -->
        <attr name="imageCornerRadius" format="dimension" />
        <attr name="imageBorderWidth" format="dimension" />
        <attr name="imageBorderColor" format="color" />
        <attr name="imageBackgroundColor" format="color" />
        
        <!-- Features -->
        <attr name="showDeleteIcon" format="boolean" />
        <attr name="deleteIconTint" format="color" />
        <attr name="showLoadingIndicator" format="boolean" />
        <attr name="enableFullScreenPreview" format="boolean" />
        <attr name="enableCameraCapture" format="boolean" />

        <!-- Accessibility -->
        <attr name="android:contentDescription" />
    </declare-styleable>

    <declare-styleable name="ImageCarousel">
        <!-- Label -->
        <attr name="carouselLabel" format="string" />
        <attr name="carouselLabelGap" format="dimension" />
        <attr name="carouselLabelTextSize" format="dimension" />
        <attr name="carouselLabelTextColor" format="color" />
        <attr name="carouselLabelTextStyle" format="enum">
            <enum name="normal" value="0" />
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="bold_italic" value="3" />
        </attr>
        
        <!-- Item Styling -->
        <attr name="carouselItemWidth" format="dimension" />
        <attr name="carouselItemHeight" format="dimension" />
        <attr name="carouselItemSpacing" format="dimension" />
        <attr name="carouselCornerRadius" format="dimension" />
        <attr name="carouselBorderWidth" format="dimension" />
        <attr name="carouselBorderColor" format="color" />
        
        <!-- Indicators -->
        <attr name="showIndicators" format="boolean" />
        <attr name="indicatorSize" format="dimension" />
        <attr name="indicatorSpacing" format="dimension" />
        <attr name="indicatorActiveColor" format="color" />
        <attr name="indicatorInactiveColor" format="color" />
        
        <!-- Features -->
        <attr name="showItemDeleteIcon" format="boolean" />
        <attr name="enableCarouselFullScreen" format="boolean" />
        <attr name="maxImageCount" format="integer" />
    </declare-styleable>

    <declare-styleable name="AdvancedButton">
        <!-- Text -->
        <attr name="buttonText" format="string" />
        
        <!-- Style and Size -->
        <attr name="buttonType" format="enum">
            <enum name="filled" value="0" />
            <enum name="outlined" value="1" />
            <enum name="text" value="2" />
            <enum name="elevated" value="3" />
            <enum name="tonal" value="4" />
            <enum name="icon" value="5" />
            <enum name="fab" value="6" />
            <enum name="extendedFab" value="7" />
            <enum name="chip" value="8" />
        </attr>
        <attr name="buttonSizeType" format="enum">
            <enum name="xs" value="0" />
            <enum name="s" value="1" />
            <enum name="m" value="2" />
            <enum name="l" value="3" />
            <enum name="xl" value="4" />
        </attr>
        <attr name="buttonCornerType" format="enum">
            <enum name="sharp" value="0" />
            <enum name="rounded" value="1" />
            <enum name="pill" value="2" />
        </attr>
        
        <!-- Colors -->
        <attr name="buttonBackgroundColor" format="color" />
        <attr name="buttonBackgroundColorPressed" format="color" />
        <attr name="buttonBackgroundColorDisabled" format="color" />
        <attr name="buttonTextColor" format="color" />
        <attr name="buttonTextColorPressed" format="color" />
        <attr name="buttonTextColorDisabled" format="color" />
        <attr name="buttonBorderColor" format="color" />
        <attr name="buttonBorderColorPressed" format="color" />
        <attr name="buttonBorderColorDisabled" format="color" />
        <attr name="buttonRippleColor" format="color" />
        <attr name="buttonLoadingColor" format="color" />
        <attr name="buttonSuccessColor" format="color" />
        <attr name="buttonErrorColor" format="color" />
        
        <!-- Gradient -->
        <attr name="buttonUseGradient" format="boolean" />
        <attr name="buttonGradientStartColor" format="color" />
        <attr name="buttonGradientEndColor" format="color" />
        <attr name="buttonGradientAngle" format="float" />
        
        <!-- Dimensions -->
        <attr name="buttonCornerRadius" format="dimension" />
        <attr name="buttonBorderWidth" format="dimension" />
        <attr name="buttonElevation" format="dimension" />
        <attr name="buttonElevationPressed" format="dimension" />
        <attr name="buttonHorizontalPadding" format="dimension" />
        <attr name="buttonVerticalPadding" format="dimension" />
        <attr name="buttonIconSpacing" format="dimension" />
        <attr name="buttonMinWidth" format="dimension" />
        <attr name="buttonMinHeight" format="dimension" />
        <attr name="buttonFullWidth" format="boolean" />
        
        <!-- Icons -->
        <attr name="buttonLeadingIcon" format="reference" />
        <attr name="buttonTrailingIcon" format="reference" />
        <attr name="buttonIconSize" format="dimension" />
        <attr name="buttonIconColor" format="color" />
        <attr name="buttonIconColorPressed" format="color" />
        <attr name="buttonIconColorDisabled" format="color" />
        <attr name="buttonShowBadge" format="boolean" />
        <attr name="buttonBadgeColor" format="color" />
        <attr name="buttonBadgeCount" format="integer" />
        
        <!-- Typography -->
        <attr name="buttonTextSize" format="dimension" />
        <attr name="buttonFontFamily" format="reference" />
        <attr name="buttonTextStyle" format="enum">
            <enum name="normal" value="0" />
            <enum name="bold" value="1" />
            <enum name="italic" value="2" />
            <enum name="boldItalic" value="3" />
        </attr>
        <attr name="buttonLetterSpacing" format="float" />
        <attr name="buttonTextTransform" format="enum">
            <enum name="none" value="0" />
            <enum name="uppercase" value="1" />
            <enum name="lowercase" value="2" />
            <enum name="capitalize" value="3" />
        </attr>
        <attr name="buttonMaxLines" format="integer" />
        
        <!-- Loading -->
        <attr name="buttonLoadingType" format="enum">
            <enum name="spinner" value="0" />
            <enum name="dots" value="1" />
            <enum name="shimmer" value="2" />
            <enum name="progress" value="3" />
        </attr>
        <attr name="buttonLoadingText" format="string" />
        <attr name="buttonShowProgressText" format="boolean" />
        
        <!-- Behavior -->
        <attr name="buttonDebounceTime" format="integer" />
        <attr name="buttonDoubleClickTime" format="integer" />
        <attr name="buttonEnableHaptic" format="boolean" />
        <attr name="buttonHapticIntensity" format="enum">
            <enum name="none" value="0" />
            <enum name="light" value="1" />
            <enum name="medium" value="2" />
            <enum name="heavy" value="3" />
        </attr>
        <attr name="buttonAnimationDuration" format="integer" />
        <attr name="buttonScaleOnPress" format="boolean" />
        <attr name="buttonScaleAmount" format="float" />
        
        <!-- Animation Flags -->
        <attr name="buttonEnableRipple" format="boolean" />
        <attr name="buttonEnableScaleAnimation" format="boolean" />
        <attr name="buttonEnableElevationAnimation" format="boolean" />
        <attr name="buttonEnablePulseAnimation" format="boolean" />
        <attr name="buttonEnableShimmer" format="boolean" />
        
        <!-- Common -->
        <attr name="android:enabled" />
    </declare-styleable>
</resources>