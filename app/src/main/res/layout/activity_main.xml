<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:src="@drawable/logo_full"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VolineUI Library Demo App"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textAlignment="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnOpenInputFieldExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Input Field Examples" />

        <Button
            android:id="@+id/btnOpenComposeInputFieldExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose InputField Examples" />

        <Button
            android:id="@+id/btnOpenRadioExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radio Examples" />

        <Button
            android:id="@+id/btnOpenComposeRadioExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose Radio Examples" />

        <Button
            android:id="@+id/btnOpenDropdownExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dropdown Examples" />

        <Button
            android:id="@+id/btnOpenComposeDropdownExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose Dropdown Examples" />

        <Button
            android:id="@+id/btnOpenSignaturePadExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Signature Pad Examples" />

        <Button
            android:id="@+id/btnOpenPermissionExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Permission Examples" />

        <Button
            android:id="@+id/btnOpenLocationExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location Examples" />

        <Button
            android:id="@+id/btnOpenPhotoCaptureExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Photo Capture Examples" />

        <Button
            android:id="@+id/btnOpenImageViewExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ImageView Examples" />

        <Button
            android:id="@+id/btnOpenComposeImageViewExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose ImageView Examples" />

        <Button
            android:id="@+id/btnOpenButtonExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Button Examples" />

        <Button
            android:id="@+id/btnOpenComposeButtonExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose Button Examples" />

        <Button
            android:id="@+id/btnOpenComposeImageCarouselExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose ImageCarousel Examples" />

        <Button
            android:id="@+id/btnOpenToastExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toast Examples" />

        <Button
            android:id="@+id/btnOpenComposeToastExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose Toast Examples" />

        <Button
            android:id="@+id/btnOpenDialogExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dialog Examples" />

        <Button
            android:id="@+id/btnOpenComposeDialogExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose Dialog Examples" />

        <Button
            android:id="@+id/btnOpenComposeDateTimePickerExamples"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compose DateTimePicker Examples" />

        <Button
            android:id="@+id/btnOpenRemoteLoggerTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remote Logger Examples" />

    </LinearLayout>

</ScrollView>