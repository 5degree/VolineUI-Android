<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PhotoCaptureManager Examples"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Camera Capture Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Camera Capture"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnCaptureNoWatermark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Capture (No Watermark)"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCaptureCachedLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Capture with Watermark (Cached Location)"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCaptureFreshLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Capture with Watermark (Fresh Location)"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

        <!-- Gallery Picker Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gallery Picker"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnPickFromGallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🖼️ Pick from Gallery (with Watermark)"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp" />

        <!-- Photo Preview Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preview"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <ImageView
            android:id="@+id/ivPhoto"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:contentDescription="Captured photo"
            android:layout_marginBottom="12dp" />

        <!-- Metadata Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Metadata"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvMetadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No photo captured yet"
            android:textSize="14sp"
            android:textColor="#666666"
            android:fontFamily="monospace"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:minHeight="100dp" />

    </LinearLayout>
</ScrollView>
