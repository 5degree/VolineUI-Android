<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:id="@+id/main"
    tools:context=".ButtonExamplesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="AdvancedButton Examples"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Section: Button Styles -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Button Styles"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Filled Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnFilled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Filled Button"/>

        <!-- Outlined Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnOutlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Outlined Button"
            app:buttonType="outlined" />

        <!-- Text Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Text Button"
            app:buttonType="text"
            app:buttonBackgroundColor="#6200EE" />

        <!-- Elevated Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnElevated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Elevated Button"
            app:buttonType="elevated"
            app:buttonBackgroundColor="#03DAC5"
            app:buttonTextColor="#000000"
            app:buttonElevation="4dp" />

        <!-- Tonal Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnTonal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Tonal Button"
            app:buttonType="tonal"
            app:buttonBackgroundColor="#6200EE" />

        <!-- Chip Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:buttonText="Chip Style"
            app:buttonType="chip"
            app:buttonSizeType="s"
            app:buttonBackgroundColor="#6200EE" />

        <!-- Section: Size Variants -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Size Variants"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnXS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonText="XS"
                app:buttonSizeType="xs"
                app:buttonFullWidth="false"
                app:buttonBackgroundColor="#FF5722" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonText="Small"
                app:buttonSizeType="s"
                app:buttonFullWidth="false"
                app:buttonBackgroundColor="#FF9800" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonText="Medium"
                app:buttonSizeType="m"
                app:buttonFullWidth="false"
                app:buttonBackgroundColor="#4CAF50" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonText="Large"
                app:buttonSizeType="l"
                app:buttonFullWidth="false"
                app:buttonBackgroundColor="#2196F3" />

        </LinearLayout>

        <!-- Section: Icons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Icons"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Leading Icon -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnLeadingIcon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Add Item"
            app:buttonLeadingIcon="@android:drawable/ic_input_add"
            app:buttonBackgroundColor="#4CAF50" />

        <!-- Trailing Icon (Clickable) -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnTrailingIcon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Send Message"
            app:buttonTrailingIcon="@android:drawable/ic_menu_send"
            app:buttonBackgroundColor="#2196F3" />

        <!-- Both Icons -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnBothIcons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:buttonText="With Both Icons"
            app:buttonLeadingIcon="@android:drawable/ic_menu_edit"
            app:buttonTrailingIcon="@android:drawable/ic_menu_more"
            app:buttonBackgroundColor="#9C27B0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Icon-only playground"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Variants"
            android:textColor="#888888"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconStandard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="standard"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_search" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconFilled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_input_add"
                app:buttonBackgroundColor="#E91E63" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconTonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonType="icon"
                app:buttonIconAppearance="tonal"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_info_details"
                app:buttonBackgroundColor="#009688" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconOutlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="outlined"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_edit"
                app:buttonBorderColor="#3F51B5"
                app:buttonIconColor="#3F51B5" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconElevated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="elevated"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_send"
                app:buttonBackgroundColor="#FF9800" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconTrailingOnly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonType="icon"
                app:buttonIconAppearance="outlined"
                app:buttonSizeType="s"
                app:buttonTrailingIcon="@android:drawable/ic_media_next"
                app:buttonBorderColor="#607D8B"
                app:buttonIconColor="#607D8B" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Sizes"
            android:textColor="#888888"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconXs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="xs"
                app:buttonLeadingIcon="@android:drawable/ic_menu_add"
                app:buttonBackgroundColor="#795548" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_call"
                app:buttonBackgroundColor="#9C27B0" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="m"
                app:buttonLeadingIcon="@android:drawable/ic_menu_camera"
                app:buttonBackgroundColor="#3F51B5" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="l"
                app:buttonLeadingIcon="@android:drawable/ic_menu_compass"
                app:buttonBackgroundColor="#2196F3" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Corners and states"
            android:textColor="#888888"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconSharp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonCornerType="sharp"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_crop"
                app:buttonBackgroundColor="#F44336" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconRounded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonCornerType="rounded"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_gallery"
                app:buttonBackgroundColor="#9C27B0" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonCornerType="pill"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_manage"
                app:buttonBackgroundColor="#3F51B5" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconDisabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_lock_idle_lock"
                app:buttonBackgroundColor="#B0BEC5" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Behaviors and effects"
            android:textColor="#888888"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_popup_sync"
                app:buttonBackgroundColor="#009688" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconSuccessError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/checkbox_on_background"
                app:buttonBackgroundColor="#4CAF50" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconInteraction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:buttonType="icon"
                app:buttonIconAppearance="outlined"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_recent_history"
                app:buttonBorderColor="#FF5722"
                app:buttonIconColor="#FF5722" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnIconGradient"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonType="icon"
                app:buttonIconAppearance="filled"
                app:buttonSizeType="s"
                app:buttonLeadingIcon="@android:drawable/ic_menu_rotate"
                app:buttonUseGradient="true"
                app:buttonGradientStartColor="#7C4DFF"
                app:buttonGradientEndColor="#448AFF" />
        </LinearLayout>

        <!-- Section: Corner Types -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Corner Types"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnSharp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:buttonText="Sharp"
                app:buttonCornerType="sharp"
                app:buttonBackgroundColor="#E91E63" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnRounded"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:buttonText="Rounded"
                app:buttonCornerType="rounded"
                app:buttonBackgroundColor="#9C27B0" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnPill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:buttonText="Pill"
                app:buttonCornerType="pill"
                app:buttonBackgroundColor="#673AB7" />

        </LinearLayout>

        <!-- Section: States -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="States"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Disabled Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnDisabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:enabled="false"
            app:buttonText="Disabled Button" />

        <!-- Loading Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Click to Load"
            app:buttonBackgroundColor="#FF5722" />

        <!-- Success/Error Button -->
        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnSuccessError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:buttonText="Click for Success"
            app:buttonBackgroundColor="#607D8B" />

        <!-- Section: Gradient -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Gradient Background"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnGradient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:buttonText="Gradient Button"
            app:buttonUseGradient="true"
            app:buttonGradientStartColor="#FF6B6B"
            app:buttonGradientEndColor="#556270"
            app:buttonCornerType="pill" />

        <!-- Section: Loading Types -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Loading Types"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnLoadingSpinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:buttonText="Spinner"
                app:buttonLoadingType="spinner"
                app:buttonBackgroundColor="#009688" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnLoadingDots"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:buttonText="Dots"
                app:buttonLoadingType="dots"
                app:buttonBackgroundColor="#00BCD4" />

            <com.cropintellix.volineui.AdvancedButton
                android:id="@+id/btnLoadingShimmer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:buttonText="Shimmer"
                app:buttonLoadingType="shimmer"
                app:buttonBackgroundColor="#03A9F4" />

        </LinearLayout>

        <!-- Section: Double Click / Long Press -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Click Interactions"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.cropintellix.volineui.AdvancedButton
            android:id="@+id/btnInteractions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:buttonText="Try Single/Double/Long Click"
            app:buttonBackgroundColor="#795548" />

        <!-- Status Display -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:background="#F5F5F5"
            android:padding="16dp"
            android:text="Status: Ready"
            android:textAlignment="center" />

    </LinearLayout>
</ScrollView>
