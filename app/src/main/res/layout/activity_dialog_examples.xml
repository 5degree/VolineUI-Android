<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".DialogExamplesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dialog Examples (View)"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <!-- Basic Dialogs Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Basic Dialogs"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSimpleDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simple Dialog" />

        <Button
            android:id="@+id/btnDialogWithCallback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dialog with Callback" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginVertical="16dp" />

        <!-- Dialog Types Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dialog Types"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSuccessDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Success Dialog" />

        <Button
            android:id="@+id/btnErrorDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Error Dialog" />

        <Button
            android:id="@+id/btnWarningDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Warning Dialog" />

        <Button
            android:id="@+id/btnInfoDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Info Dialog" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginVertical="16dp" />

        <!-- Action Dialogs Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Action Dialogs"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnConfirmDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmation Dialog" />

        <Button
            android:id="@+id/btnDestructiveDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Destructive Dialog" />

        <Button
            android:id="@+id/btnTwoButtonDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Two Button Dialog" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginVertical="16dp" />

        <!-- Custom Dialogs Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Dialogs"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnNonCancelableDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Non-Cancelable Dialog" />

        <Button
            android:id="@+id/btnCustomButtonStyles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Button Styles" />

        <Button
            android:id="@+id/btnNoGradientDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Flat (No Gradient) Buttons" />

        <Button
            android:id="@+id/btnBuilderPatternDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Builder Pattern Dialog" />

        <Button
            android:id="@+id/btnCustomIconDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Icon Dialog" />

        <Button
            android:id="@+id/btnNoIconDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Icon Dialog" />

        <Button
            android:id="@+id/btnLongMessageDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Long Message Dialog" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>
